# StockData 生产环境配置示例
# 复制此文件为 .env 并填入实际值

# ===================
# 必需的环境变量
# ===================

# StockData 根目录
export STOCKDATA_ROOT="/Users/bruce/workspace/trade/StockData"

# Tushare Token (从 https://tushare.pro 注册获取)
export TUSHARE_TOKEN="your_tushare_token_here"

# ===================
# 邮件告警配置
# ===================

# QQ邮箱 SMTP 密码 (在邮箱设置中开启SMTP后获取)
export EMAIL_PASSWORD="your_smtp_password_here"

# SMTP 配置 (可选，使用默认值)
# export EMAIL_SMTP_HOST="smtp.qq.com"
# export EMAIL_SMTP_PORT="587"
# export EMAIL_USERNAME="bruceleexiaokan@qq.com"
# export EMAIL_TO="bruceleexiaokan@qq.com"

# ===================
# 备份配置 (可选)
# ===================

# 备份根目录 (可选，使用默认值)
# export BACKUP_ROOT="/Users/bruce/backup/StockData"
